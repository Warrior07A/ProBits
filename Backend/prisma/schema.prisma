// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
 student
 teacher
}

model users {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     ROLE?   @default(teacher)
  createdAt DateTime @default(now())


  teacherRooms Rooms[] @relation("teacher")
  studentRooms Rooms[] @relation("student")

}

model Rooms {
  id                String @id @default(uuid())
  teacher_id        String    
  student_id        String?
  createdAt DateTime @default(now())


  user1  users @relation(name : "teacher" , fields: [teacher_id] , references: [id] ) 
  user2  users? @relation(name : "student" , fields: [student_id] , references: [id] )   
}

